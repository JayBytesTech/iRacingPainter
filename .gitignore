# Python
.venv/
__pycache__/
*.pyc

# Generated render output
out/

# Template-derived art (regenerate with: python -m iracing_painter.extract <template>)
templates/*/base.png
templates/*/spec_base.png
templates/*/reference/
templates/*/number_blocks.json

# Auto-generated zone segmentation (regenerate with: python -m iracing_painter.zones <template>)
# NOTE: labels.json is hand-authored and IS tracked.
templates/*/zones/segments.png
templates/*/zones/segments.json
templates/*/zones/segments_preview.png

# Auto-generated calibration skins (regenerate with: python -m iracing_painter.calibrate <template>)
templates/*/calibration/

