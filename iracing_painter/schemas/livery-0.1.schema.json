{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/JayBytesTech/iRacingPainter/schemas/livery-0.1.schema.json",
  "title": "iRacing Painter Livery Spec",
  "description": "The contract between livery design intent and the deterministic renderer. v0.1: solid fills only; elements and materials are part of the contract but rendered in later phases.",
  "type": "object",
  "required": ["schema_version", "template", "base"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "const": "0.1" },
    "template": {
      "type": "string",
      "minLength": 1,
      "description": "Template id, e.g. 'porsche_992_gt3' (a dir under templates/)."
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "name": { "type": "string" },
        "author": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "palette": {
      "type": "object",
      "description": "Named colors for human reference/reuse. Not yet referenced by fills in v0.1.",
      "additionalProperties": { "$ref": "#/$defs/color" }
    },
    "base": {
      "$ref": "#/$defs/surface",
      "description": "Fill for the whole car body; zones override on top."
    },
    "zones": {
      "type": "object",
      "description": "Per-zone fill overrides. Keys must be a zone OR group name from the template's zones/labels.json.",
      "additionalProperties": { "$ref": "#/$defs/surface" }
    },
    "elements": {
      "type": "array",
      "description": "Ordered draw list, composited on top of fills. v0.1 renders 'number'; more element types added in later phases.",
      "items": { "$ref": "#/$defs/element" }
    },
    "materials": {
      "type": "object",
      "additionalProperties": false,
      "description": "Surface materials -> spec map. Accepted in v0.1; spec-map generation lands in P5.",
      "properties": {
        "default": { "$ref": "#/$defs/material" },
        "zones": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/material" }
        }
      }
    }
  },
  "$defs": {
    "color": {
      "type": "string",
      "pattern": "^#[0-9a-fA-F]{6}$",
      "description": "Hex color, #rrggbb."
    },
    "fill": {
      "type": "object",
      "required": ["type"],
      "description": "Extensible fill. v0.1 supports 'solid' and 'pattern' (a stock recolor design); gradient/texture/generated come later.",
      "oneOf": [
        {
          "additionalProperties": false,
          "required": ["type", "color"],
          "properties": {
            "type": { "const": "solid" },
            "color": { "$ref": "#/$defs/color" }
          }
        },
        {
          "additionalProperties": false,
          "required": ["type", "pattern", "colors"],
          "description": "A stock paint pattern recolored with up to 3 colors. Only valid on 'base' (it maps the whole body).",
          "properties": {
            "type": { "const": "pattern" },
            "pattern": { "type": "string", "minLength": 1 },
            "colors": {
              "type": "array",
              "items": { "$ref": "#/$defs/color" },
              "minItems": 1,
              "maxItems": 3
            }
          }
        }
      ]
    },
    "surface": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fill"],
      "properties": { "fill": { "$ref": "#/$defs/fill" } }
    },
    "material": { "enum": ["gloss", "matte", "metallic", "chrome"] },
    "element": {
      "type": "object",
      "required": ["type"],
      "oneOf": [
        {
          "additionalProperties": false,
          "required": ["type", "value"],
          "description": "Racing number rendered into the template's number blocks.",
          "properties": {
            "type": { "const": "number" },
            "value": { "type": "string", "minLength": 1, "maxLength": 3 },
            "color": { "$ref": "#/$defs/color" },
            "outline": { "$ref": "#/$defs/color" }
          }
        },
        {
          "additionalProperties": false,
          "required": ["type", "asset"],
          "description": "Logo/decal from the asset library, anchored to a zone/group centroid or explicit UV coords.",
          "properties": {
            "type": { "const": "logo" },
            "asset": { "type": "string", "minLength": 1 },
            "zone": { "type": "string" },
            "at": {
              "type": "array",
              "items": { "type": "integer" },
              "minItems": 2,
              "maxItems": 2
            },
            "scale": { "type": "number", "exclusiveMinimum": 0, "maximum": 5 },
            "width": { "type": "integer", "exclusiveMinimum": 0 },
            "rotation": { "type": "number" },
            "opacity": { "type": "number", "minimum": 0, "maximum": 1 }
          }
        }
      ]
    }
  }
}
